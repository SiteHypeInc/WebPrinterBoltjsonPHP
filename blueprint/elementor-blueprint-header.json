              "settings": {
                "editor": "<a href=\"/\" style=\"color: #111111; text-decoration: none; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500; margin-right: 40px;\">Home</a><a href=\"/services\" style=\"color: #111111; text-decoration: none; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500; margin-right: 40px;\">Services</a><a href=\"/about\" style=\"color: #111111; text-decoration: none; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500; margin-right: 40px;\">About</a><a href=\"/contact\" style=\"color: #111111; text-decoration: none; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500;\">Contact</a>"
              }
            },
            {
