            "flex_direction_mobile": "row",
            "flex_align_items": "center",
            "flex_gap": {
              "unit": "px",
              "size": "48"
            },
            "flex_gap_tablet": {
              "unit": "px",
              "size": "32"
            },
            "flex_gap_mobile": {
              "unit": "px",
              "size": "24"
