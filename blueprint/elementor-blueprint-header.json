        "padding": {
          "unit": "px",
          "top": "24",
          "right": "80",
          "bottom": "24",
          "left": "80"
        },
        "padding_tablet": {
          "unit": "px",
          "top": "20",
          "right": "48",
          "bottom": "20",
          "left": "48"
        },
        "padding_mobile": {
          "unit": "px",
          "top": "16",
          "right": "24",
          "bottom": "16",
          "left": "24"
        },
        "border_bottom_border": "solid",
