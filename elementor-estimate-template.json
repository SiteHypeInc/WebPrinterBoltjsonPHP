          "elements": [
            {
              "id": "hero-heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Get Your Free Estimate",
                "align": "center",
                "title_color": "#ffffff",
                "typography_typography": "custom",
                "typography_font_size": {
                  "unit": "px",
                  "size": 48
                },
                "typography_font_weight": "700",
                "typography_line_height": {
                  "unit": "em",
                  "size": 1.2
                }
              }
            },
            {
              "id": "hero-subtext",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"text-align: center; color: #e0e7ff; font-size: 20px; margin-top: 16px;\">{{response_time}} response • 100% Free • No Obligation</p>",
                "text_color": "#e0e7ff"
