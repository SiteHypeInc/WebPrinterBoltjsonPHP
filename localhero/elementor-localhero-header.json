{
  "version": "0.4",
  "title": "Localhero Header",
  "type": "page",
  "content": [
    {
      "id": "header-main",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "padding": {
          "unit": "px",
          "top": "20",
          "right": "40",
          "bottom": "20",
          "left": "40"
        },
        "padding_tablet": {
          "unit": "px",
          "top": "15",
          "right": "20",
          "bottom": "15",
          "left": "20"
        },
        "padding_mobile": {
          "unit": "px",
          "top": "15",
          "right": "15",
          "bottom": "15",
          "left": "15"
        },
        "box_shadow_box_shadow_type": "yes",
        "box_shadow_box_shadow": {
          "horizontal": 0,
          "vertical": 2,
          "blur": 8,
          "color": "rgba(0,0,0,0.08)"
        },
        "position": "fixed",
        "z_index": 1000,
        "width": {
          "unit": "%",
          "size": 100
        },
        "width_tablet": {
          "unit": "%",
          "size": 100
        },
        "width_mobile": {
          "unit": "%",
          "size": 100
        },
        "flex_direction": "row",
        "flex_align_items": "center",
        "flex_justify_content": "space-between"
      },
      "elements": [
        {
          "id": "logo-container",
          "elType": "container",
          "settings": {
            "width": {
              "unit": "px",
              "size": 200
            },
            "width_tablet": {
              "unit": "px",
              "size": 160
            },
            "width_mobile": {
              "unit": "px",
              "size": 140
            }
          },
          "elements": [
            {
              "id": "logo-image",
              "elType": "widget",
              "widgetType": "image",
              "settings": {
                "image": {
                  "url": ""
                },
                "image_size": "full",
                "width": {
                  "unit": "%",
                  "size": 100
                },
                "width_tablet": {
                  "unit": "%",
                  "size": 100
                },
                "width_mobile": {
                  "unit": "%",
                  "size": 100
                },
                "link": {
                  "url": "/"
                }
              }
            }
          ]
        },
        {
          "id": "nav-container",
          "elType": "container",
          "settings": {
            "flex_direction": "row",
            "flex_align_items": "center",
            "flex_gap": {
              "unit": "px",
              "size": 30
            },
            "flex_gap_tablet": {
              "unit": "px",
              "size": 20
            },
            "flex_gap_mobile": {
              "unit": "px",
              "size": 15
            }
          },
          "elements": [
            {
              "id": "nav-links",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='display:flex;gap:30px;align-items:center;'><a href='/' style='color:#333333;text-decoration:none;font-family:Open Sans,sans-serif;font-size:16px;font-weight:600;transition:color 0.3s;'>Home</a><a href='/services' style='color:#333333;text-decoration:none;font-family:Open Sans,sans-serif;font-size:16px;font-weight:600;transition:color 0.3s;'>Services</a><a href='/about' style='color:#333333;text-decoration:none;font-family:Open Sans,sans-serif;font-size:16px;font-weight:600;transition:color 0.3s;'>About</a><a href='/contact' style='color:#333333;text-decoration:none;font-family:Open Sans,sans-serif;font-size:16px;font-weight:600;transition:color 0.3s;'>Contact</a></div>",
                "_inline_size": 0
              }
            },
            {
              "id": "cta-button",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Get Free Quote",
                "link": {
                  "url": "/quote"
                },
                "size": "md",
                "button_background_color": "#C62828",
                "button_background_hover_color": "#9A1F1F",
                "button_text_color": "#FFFFFF",
                "typography_font_family": "Nunito",
                "typography_font_size": {
                  "unit": "px",
                  "size": 16
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 15
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 14
                },
                "typography_font_weight": "700",
                "border_radius": {
                  "unit": "px",
                  "top": "6",
                  "right": "6",
                  "bottom": "6",
                  "left": "6"
                },
                "button_padding": {
                  "unit": "px",
                  "top": "14",
                  "right": "28",
                  "bottom": "14",
                  "left": "28"
                },
                "button_padding_tablet": {
                  "unit": "px",
                  "top": "12",
                  "right": "24",
                  "bottom": "12",
                  "left": "24"
                },
                "button_padding_mobile": {
                  "unit": "px",
                  "top": "10",
                  "right": "20",
                  "bottom": "10",
                  "left": "20"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}