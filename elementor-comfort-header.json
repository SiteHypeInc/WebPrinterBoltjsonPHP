{
  "content": [
    {
      "id": "header-container",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "padding": {
          "unit": "px",
          "top": "20",
          "right": "80",
          "bottom": "20",
          "left": "80"
        },
        "padding_tablet": {
          "unit": "px",
          "top": "18",
          "right": "48",
          "bottom": "18",
          "left": "48"
        },
        "padding_mobile": {
          "unit": "px",
          "top": "16",
          "right": "24",
          "bottom": "16",
          "left": "24"
        },
        "box_shadow_box_shadow_type": "yes",
        "box_shadow_box_shadow": {
          "horizontal": "0",
          "vertical": "2",
          "blur": "12",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.06)"
        },
        "flex_direction": "row",
        "flex_direction_tablet": "row",
        "flex_direction_mobile": "column",
        "flex_align_items": "center",
        "flex_justify_content": "space-between",
        "flex_gap": {
          "unit": "px",
          "size": "40"
        },
        "flex_gap_tablet": {
          "unit": "px",
          "size": "32"
        },
        "flex_gap_mobile": {
          "unit": "px",
          "size": "24"
        }
      },
      "elements": [
        {
          "id": "logo-container",
          "elType": "container",
          "settings": {
            "width": {
              "unit": "%",
              "size": "20"
            },
            "width_tablet": {
              "unit": "%",
              "size": "30"
            },
            "width_mobile": {
              "unit": "%",
              "size": "100"
            },
            "flex_align_items": "center"
          },
          "elements": [
            {
              "id": "logo",
              "elType": "widget",
              "widgetType": "image",
              "settings": {
                "image": {
                  "url": ""
                },
                "width": {
                  "unit": "px",
                  "size": "180"
                },
                "width_tablet": {
                  "unit": "px",
                  "size": "160"
                },
                "width_mobile": {
                  "unit": "px",
                  "size": "140"
                }
              }
            }
          ]
        },
        {
          "id": "nav-container",
          "elType": "container",
          "settings": {
            "width": {
              "unit": "%",
              "size": "50"
            },
            "width_tablet": {
              "unit": "%",
              "size": "40"
            },
            "width_mobile": {
              "unit": "%",
              "size": "100"
            },
            "flex_justify_content": "center"
          },
          "elements": [
            {
              "id": "nav-links",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<nav style='display: flex; gap: 32px; flex-wrap: wrap; justify-content: center;'><a href='/' style='color: #1A365D; text-decoration: none; font-weight: 600; font-size: 15px;'>Home</a><a href='/services' style='color: #1A365D; text-decoration: none; font-weight: 600; font-size: 15px;'>Services</a><a href='/about' style='color: #1A365D; text-decoration: none; font-weight: 600; font-size: 15px;'>About</a><a href='/contact' style='color: #1A365D; text-decoration: none; font-weight: 600; font-size: 15px;'>Contact</a></nav>",
                "align": "center"
              }
            }
          ]
        },
        {
          "id": "cta-container",
          "elType": "container",
          "settings": {
            "width": {
              "unit": "%",
              "size": "30"
            },
            "width_tablet": {
              "unit": "%",
              "size": "30"
            },
            "width_mobile": {
              "unit": "%",
              "size": "100"
            },
            "flex_justify_content": "flex-end",
            "flex_justify_content_mobile": "center"
          },
          "elements": [
            {
              "id": "cta-button",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "24/7 Emergency",
                "link": {
                  "url": "/quote"
                },
                "size": "md",
                "typography_typography": "custom",
                "typography_font_size": {
                  "unit": "px",
                  "size": "15"
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": "14"
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": "14"
                },
                "typography_font_weight": "700",
                "button_text_color": "#FFFFFF",
                "background_color": "#DC2626",
                "border_radius": {
                  "unit": "px",
                  "top": "6",
                  "right": "6",
                  "bottom": "6",
                  "left": "6"
                },
                "button_padding": {
                  "unit": "px",
                  "top": "14",
                  "right": "28",
                  "bottom": "14",
                  "left": "28"
                },
                "button_padding_tablet": {
                  "unit": "px",
                  "top": "12",
                  "right": "24",
                  "bottom": "12",
                  "left": "24"
                },
                "button_padding_mobile": {
                  "unit": "px",
                  "top": "12",
                  "right": "24",
                  "bottom": "12",
                  "left": "24"
                },
                "hover_color": "#FFFFFF",
                "button_background_hover_color": "#B91C1C"
              }
            }
          ]
        }
      ]
    }
  ]
}
