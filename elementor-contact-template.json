{
  "content": [
    {
      "id": "hero-section",
      "elType": "section",
      "settings": {
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 1140
        },
        "gap": "default",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20"
        },
        "background_background": "gradient",
        "background_color": "#059669",
        "background_color_b": "#10b981",
        "background_gradient_type": "linear",
        "background_gradient_angle": {
          "unit": "deg",
          "size": 135
        }
      },
      "elements": [
        {
          "id": "hero-column",
          "elType": "column",
          "settings": {
            "_column_size": 100,
            "content_position": "middle"
          },
          "elements": [
            {
              "id": "hero-heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Contact Us",
                "align": "center",
                "title_color": "#ffffff",
                "typography_typography": "custom",
                "typography_font_size": {
                  "unit": "px",
                  "size": 48
                },
                "typography_font_weight": "700",
                "typography_line_height": {
                  "unit": "em",
                  "size": 1.2
                }
              }
            },
            {
              "id": "hero-subtext",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"text-align: center; color: #d1fae5; font-size: 20px; margin-top: 16px;\">We're here to help! Reach out anytime and we'll get back to you quickly.</p>",
                "text_color": "#d1fae5"
              }
            }
          ]
        }
      ]
    },
