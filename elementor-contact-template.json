    {
      "id": "form-section",
      "elType": "section",
      "settings": {
        "layout": "boxed",
        "content_width": {
          "unit": "px",
          "size": 800
        },
        "gap": "default",
        "padding": {
          "unit": "px",
          "top": "60",
          "right": "20",
          "bottom": "60",
          "left": "20"
        },
        "background_background": "classic",
        "background_color": "#f9fafb"
      },
      "elements": [
        {
          "id": "form-column",
          "elType": "column",
          "settings": {
            "_column_size": 100
          },
          "elements": [
            {
              "id": "form-heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Send Us a Message",
                "align": "center",
                "title_color": "#1f2937",
                "typography_typography": "custom",
                "typography_font_size": {
                  "unit": "px",
                  "size": 32
                },
                "typography_font_weight": "700"
              }
            },
            {
              "id": "form-description",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"text-align: center; color: #6b7280; font-size: 16px; margin-bottom: 32px;\">Fill out the form below and we'll get back to you as soon as possible</p>"
              }
            },
            {
              "id": "contact-form",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<form method=\"post\" action=\"\" style=\"max-width: 600px; margin: 0 auto;\">\n  <div style=\"margin-bottom: 20px;\">\n    <label for=\"name\" style=\"display: block; margin-bottom: 8px; color: #374151; font-weight: 600;\">Name *</label>\n    <input type=\"text\" id=\"name\" name=\"name\" required style=\"width: 100%; padding: 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 16px;\" />\n  </div>\n  \n  <div style=\"margin-bottom: 20px;\">\n    <label for=\"phone\" style=\"display: block; margin-bottom: 8px; color: #374151; font-weight: 600;\">Phone *</label>\n    <input type=\"tel\" id=\"phone\" name=\"phone\" required style=\"width: 100%; padding: 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 16px;\" />\n  </div>\n  \n  <div style=\"margin-bottom: 20px;\">\n    <label for=\"email\" style=\"display: block; margin-bottom: 8px; color: #374151; font-weight: 600;\">Email *</label>\n    <input type=\"email\" id=\"email\" name=\"email\" required style=\"width: 100%; padding: 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 16px;\" />\n  </div>\n  \n  <div style=\"margin-bottom: 20px;\">\n    <label for=\"message\" style=\"display: block; margin-bottom: 8px; color: #374151; font-weight: 600;\">Message *</label>\n    <textarea id=\"message\" name=\"message\" rows=\"5\" required style=\"width: 100%; padding: 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 16px; resize: vertical;\"></textarea>\n  </div>\n  \n  <div style=\"text-align: center;\">\n    <button type=\"submit\" style=\"background: #059669; color: white; padding: 14px 32px; border: none; border-radius: 6px; font-size: 18px; font-weight: 600; cursor: pointer; transition: background 0.3s;\">Send Message</button>\n  </div>\n</form>"
              }
            }
          ]
        }
      ]
    },
