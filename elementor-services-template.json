  {
    "id": "how-it-works",
    "elType": "section",
    "settings": {
      "layout": "boxed",
      "background_background": "classic",
      "background_color": "#ffffff",
      "padding": {"unit": "px", "top": "80", "right": "20", "bottom": "80", "left": "20"}
    },
    "elements": [
      {
        "id": "how-it-works-heading-col",
        "elType": "column",
        "settings": {"_column_size": 100},
        "elements": [
          {
            "id": "how-it-works-heading",
            "elType": "widget",
            "widgetType": "heading",
            "settings": {
              "title": "How It Works",
              "align": "center",
              "title_color": "#1f2937",
              "typography_font_size": {"unit": "px", "size": 36},
              "typography_font_weight": "700"
            }
          }
        ]
      },
      {
        "id": "how-it-works-col-1",
        "elType": "column",
        "settings": {"_column_size": 33},
        "elements": [
          {
            "id": "step-1",
            "elType": "widget",
            "widgetType": "icon-box",
            "settings": {
              "title_text": "1. {{step_1}}",
              "description_text": "Contact us by phone or online to discuss your service needs.",
              "icon": {"value": "fas fa-phone", "library": "fa-solid"},
              "icon_color": "#3b82f6",
              "icon_size": {"unit": "px", "size": 50},
              "title_color": "#1f2937",
              "description_color": "#6b7280",
              "position": "top",
              "content_vertical_alignment": "top"
            }
          }
        ]
      },
      {
        "id": "how-it-works-col-2",
        "elType": "column",
        "settings": {"_column_size": 33},
        "elements": [
          {
            "id": "step-2",
            "elType": "widget",
            "widgetType": "icon-box",
            "settings": {
              "title_text": "2. {{step_2}}",
              "description_text": "We arrange a convenient time for our experts to visit your location.",
              "icon": {"value": "fas fa-calendar-alt", "library": "fa-solid"},
              "icon_color": "#10b981",
              "icon_size": {"unit": "px", "size": 50},
              "title_color": "#1f2937",
              "description_color": "#6b7280",
              "position": "top",
              "content_vertical_alignment": "top"
            }
          }
        ]
      },
      {
        "id": "how-it-works-col-3",
        "elType": "column",
        "settings": {"_column_size": 33},
        "elements": [
          {
            "id": "step-3",
            "elType": "widget",
            "widgetType": "icon-box",
            "settings": {
              "title_text": "3. {{step_3}}",
              "description_text": "Our team completes the work to your satisfaction with quality results.",
              "icon": {"value": "fas fa-check-circle", "library": "fa-solid"},
              "icon_color": "#059669",
              "icon_size": {"unit": "px", "size": 50},
              "title_color": "#1f2937",
              "description_color": "#6b7280",
              "position": "top",
              "content_vertical_alignment": "top"
            }
          }
        ]
      }
    ]
