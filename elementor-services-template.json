[
  {
    "id": "services-hero",
    "elType": "section",
    "settings": {
      "layout": "full_width",
      "background_background": "gradient",
      "background_color": "#1e3a8a",
      "background_color_b": "#3b82f6",
      "background_gradient_angle": {"unit": "deg", "size": 135},
      "padding": {"unit": "px", "top": "100", "right": "20", "bottom": "100", "left": "20"}
    },
    "elements": [
      {
        "id": "services-hero-col",
        "elType": "column",
        "settings": {"_column_size": 100},
        "elements": [
          {
            "id": "services-hero-heading",
            "elType": "widget",
            "widgetType": "heading",
            "settings": {
              "title": "Our {{trade}} Services",
              "align": "center",
              "title_color": "#ffffff",
              "typography_font_size": {"unit": "px", "size": 48},
              "typography_font_weight": "700"
            }
          },
          {
            "id": "services-hero-tagline",
            "elType": "widget",
            "widgetType": "text-editor",
            "settings": {
              "editor": "<p style='text-align: center; color: #e0e7ff; font-size: 20px; margin-top: 10px;'>{{tagline}}</p>",
              "align": "center"
            }
          }
        ]
      }
    ]
  },
