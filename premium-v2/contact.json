
{
  "version": "0.4",
  "title": "Premium Contact",
  "type": "page",
  "content": [
    {
      "id": "prem-contact-hero",
      "elType": "container",
      "settings": { "content_width": "full", "background_background": "classic", "background_color": "#FAFAFA", "min_height": { "unit": "vh", "size": 40 }, "padding": { "unit": "px", "top": 140, "right": 40, "bottom": 80, "left": 40, "isLinked": false }, "flex_direction": "column", "flex_align_items": "center", "flex_justify_content": "center", "flex_gap": { "unit": "px", "size": 16 } },
      "elements": [
        { "id": "prem-ct-h1", "elType": "widget", "widgetType": "heading", "settings": { "title": "Contact Us", "html_tag": "h1", "align": "center", "typography_font_family": "Playfair Display", "typography_font_size": { "unit": "px", "size": 52 }, "typography_font_weight": "600", "color": "#1A3A5C" } },
        { "id": "prem-ct-sub", "elType": "widget", "widgetType": "heading", "settings": { "title": "We'd Love to Hear From You", "html_tag": "h2", "align": "center", "typography_font_family": "Lato", "typography_font_size": { "unit": "px", "size": 22 }, "typography_font_weight": "300", "color": "#2D2D2D" } }
      ]
    },
    {
      "id": "prem-contact-body",
      "elType": "container",
      "settings": { "content_width": "full", "background_background": "classic", "background_color": "#FFFFFF", "padding": { "unit": "px", "top": 100, "right": 40, "bottom": 100, "left": 40, "isLinked": false }, "flex_direction": "row", "flex_wrap": "wrap", "flex_gap": { "unit": "px", "size": 70 }, "flex_justify_content": "center" },
      "elements": [
        {
          "id": "prem-contact-info",
          "elType": "container",
          "settings": { "width": { "unit": "%", "size": 35 }, "width_tablet": { "unit": "%", "size": 100 }, "width_mobile": { "unit": "%", "size": 100 }, "flex_direction": "column", "flex_gap": { "unit": "px", "size": 32 } },
          "elements": [
            { "id": "prem-ci-title", "elType": "widget", "widgetType": "heading", "settings": { "title": "Get In Touch", "html_tag": "h2", "typography_font_family": "Playfair Display", "typography_font_size": { "unit": "px", "size": 34 }, "typography_font_weight": "600", "color": "#1A3A5C" } },
            { "id": "prem-ci-phone", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='color:#1A3A5C;font-family:Lato,sans-serif;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;'>Phone</p><p style='color:#2D2D2D;font-family:Lato,sans-serif;font-size:20px;'><a href='tel:[PHONE]' style='color:#2D2D2D;text-decoration:none;'>[PHONE]</a></p>" } },
            { "id": "prem-ci-email", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='color:#1A3A5C;font-family:Lato,sans-serif;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;'>Email</p><p style='color:#2D2D2D;font-family:Lato,sans-serif;font-size:18px;'><a href='mailto:[EMAIL]' style='color:#2D2D2D;text-decoration:none;'>[EMAIL]</a></p>" } },
            { "id": "prem-ci-address", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='color:#1A3A5C;font-family:Lato,sans-serif;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;'>Address</p><p style='color:#2D2D2D;font-family:Lato,sans-serif;font-size:17px;'>[ADDRESS]</p>" } },
            { "id": "prem-ci-area", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='color:#1A3A5C;font-family:Lato,sans-serif;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;'>Service Area</p><p style='color:#2D2D2D;font-family:Lato,sans-serif;font-size:17px;'>[CITY, STATE] and surrounding areas</p>" } }
          ]
        },
        {
          "id": "prem-contact-cta",
          "elType": "container",
          "settings": { "width": { "unit": "%", "size": 45 }, "width_tablet": { "unit": "%", "size": 100 }, "width_mobile": { "unit": "%", "size": 100 }, "background_background": "classic", "background_color": "#FAFAFA", "border_border": "solid", "border_width": { "unit": "px", "top": 1, "right": 1, "bottom": 1, "left": 1, "isLinked": true }, "border_color": "#E5E5E5", "padding": { "unit": "px", "top": 48, "right": 40, "bottom": 48, "left": 40, "isLinked": false }, "flex_direction": "column", "flex_gap": { "unit": "px", "size": 24 } },
          "elements": [
            { "id": "prem-cta-title", "elType": "widget", "widgetType": "heading", "settings": { "title": "Request a Free Estimate", "html_tag": "h2", "typography_font_family": "Playfair Display", "typography_font_size": { "unit": "px", "size": 30 }, "typography_font_weight": "600", "color": "#1A3A5C" } },
            { "id": "prem-cta-text", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "Call us at <strong style='color:#1A3A5C;'>[PHONE]</strong> or visit our quote page for a detailed estimate.", "typography_font_family": "Lato", "typography_font_size": { "unit": "px", "size": 16 }, "text_color": "#444444" } },
            { "id": "prem-cta-btn", "elType": "widget", "widgetType": "button", "settings": { "text": "Get a Free Quote", "link": { "url": "/quote" }, "size": "lg", "button_background_color": "#1A3A5C", "button_text_color": "#FFFFFF", "border_radius": { "unit": "px", "top": 2, "right": 2, "bottom": 2, "left": 2, "isLinked": true }, "button_padding": { "unit": "px", "top": 16, "right": 40, "bottom": 16, "left": 40, "isLinked": false } } }
          ]
        }
      ]
    }
  ]
}