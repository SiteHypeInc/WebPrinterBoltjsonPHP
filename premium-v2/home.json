{
  "version": "0.4",
  "title": "Premium Home",
  "type": "page",
  "content": [
    {
      "id": "premium-home-hero",
      "elType": "container",
      "settings": {
        "_wp_img": "hero",
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#FAFAFA",
        "background_image": { "url": "" },
        "background_position": "center center",
        "background_size": "cover",
        "min_height": { "unit": "vh", "size": 90 },
        "padding": { "unit": "px", "top": 120, "right": 40, "bottom": 120, "left": 40, "isLinked": false },
        "padding_tablet": { "unit": "px", "top": 80, "right": 30, "bottom": 80, "left": 30, "isLinked": false },
        "padding_mobile": { "unit": "px", "top": 60, "right": 20, "bottom": 60, "left": 20, "isLinked": false },
        "flex_direction": "column",
        "flex_align_items": "center",
        "flex_justify_content": "center",
        "flex_gap": { "unit": "px", "size": 24 },
        "position": "relative"
      },
      "elements": [
        {
          "id": "premium-hero-overlay",
          "elType": "container",
          "settings": {
            "position": "absolute",
            "width": { "unit": "%", "size": 100 },
            "height": { "unit": "%", "size": 100 },
            "background_background": "classic",
            "background_color": "#FAFAFAF0",
            "z_index": 1
          }
        },
        {
          "id": "premium-hero-inner",
          "elType": "container",
          "settings": {
            "flex_direction": "column",
            "flex_align_items": "center",
            "flex_gap": { "unit": "px", "size": 24 },
            "width": { "unit": "%", "size": 100 },
            "max_width": { "unit": "px", "size": 900 },
            "z_index": 2
          },
          "elements": [
            {
              "id": "premium-hero-company",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "[COMPANY NAME]",
                "html_tag": "h1",
                "color": "#1A3A5C",
                "typography_font_family": "Playfair Display",
                "typography_font_size": { "unit": "px", "size": 64 },
                "typography_font_size_tablet": { "unit": "px", "size": 48 },
                "typography_font_size_mobile": { "unit": "px", "size": 36 },
                "typography_font_weight": "600",
                "typography_line_height": { "unit": "em", "size": 1.2 },
                "align": "center"
              }
            },
            {
              "id": "premium-hero-headline",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "[HERO HEADLINE]",
                "html_tag": "h2",
                "color": "#2D2D2D",
                "typography_font_family": "Lato",
                "typography_font_size": { "unit": "px", "size": 28 },
                "typography_font_size_tablet": { "unit": "px", "size": 24 },
                "typography_font_size_mobile": { "unit": "px", "size": 20 },
                "typography_font_weight": "300",
                "align": "center"
              }
            },
            {
              "id": "premium-hero-sub",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color:#2D2D2D;font-family:Lato,sans-serif;font-size:18px;line-height:1.7;text-align:center;max-width:700px;'>[HERO SUB]</p>",
                "align": "center"
              }
            },
            {
              "id": "premium-hero-cta-row",
              "elType": "container",
              "settings": {
                "flex_direction": "row",
                "flex_gap": { "unit": "px", "size": 16 },
                "flex_wrap": "wrap",
                "flex_justify_content": "center"
              },
              "elements": [
                {
                  "id": "premium-hero-btn-primary",
                  "elType": "widget",
                  "widgetType": "button",
                  "settings": {
                    "text": "Get a Free Quote",
                    "link": { "url": "/quote" },
                    "align": "center",
                    "size": "lg",
                    "typography_font_family": "Lato",
                    "typography_font_size": { "unit": "px", "size": 16 },
                    "typography_font_weight": "500",
                    "typography_letter_spacing": { "unit": "px", "size": 0.5 },
                    "button_background_color": "#1A3A5C",
                    "button_text_color": "#FFFFFF",
                    "border_radius": { "unit": "px", "top": 2, "right": 2, "bottom": 2, "left": 2, "isLinked": true },
                    "button_padding": { "unit": "px", "top": 18, "right": 36, "bottom": 18, "left": 36, "isLinked": false },
                    "button_hover_background_color": "#0F2A42"
                  }
                },
                {
                  "id": "premium-hero-btn-phone",
                  "elType": "widget",
                  "widgetType": "button",
                  "settings": {
                    "text": "Call [PHONE]",
                    "link": { "url": "tel:[PHONE]" },
                    "align": "center",
                    "size": "lg",
                    "typography_font_family": "Lato",
                    "typography_font_size": { "unit": "px", "size": 16 },
                    "typography_font_weight": "500",
                    "typography_letter_spacing": { "unit": "px", "size": 0.5 },
                    "button_background_color": "transparent",
                    "button_text_color": "#1A3A5C",
                    "border_border": "solid",
                    "border_width": { "unit": "px", "top": 2, "right": 2, "bottom": 2, "left": 2, "isLinked": true },
                    "border_color": "#1A3A5C",
                    "border_radius": { "unit": "px", "top": 2, "right": 2, "bottom": 2, "left": 2, "isLinked": true },
                    "button_padding": { "unit": "px", "top": 18, "right": 36, "bottom": 18, "left": 36, "isLinked": false },
                    "button_hover_background_color": "#EEF2F7"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
