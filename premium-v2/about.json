{
  "version": "0.4",
  "title": "Premium About",
  "type": "page",
  "content": [
    {
      "id": "prem-about-hero",
      "elType": "container",
      "settings": {
        "_wp_img": "about",
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#FAFAFA",
        "background_image": { "url": "" },
        "background_position": "center center",
        "background_size": "cover",
        "min_height": { "unit": "vh", "size": 50 },
        "padding": { "unit": "px", "top": 140, "right": 40, "bottom": 80, "left": 40, "isLinked": false },
        "padding_tablet": { "unit": "px", "top": 100, "right": 30, "bottom": 60, "left": 30, "isLinked": false },
        "padding_mobile": { "unit": "px", "top": 80, "right": 20, "bottom": 50, "left": 20, "isLinked": false },
        "flex_direction": "column",
        "flex_align_items": "center",
        "flex_justify_content": "center",
        "position": "relative"
      },
      "elements": [
        {
          "id": "prem-about-overlay",
          "elType": "container",
          "settings": {
            "position": "absolute",
            "width": { "unit": "%", "size": 100 },
            "height": { "unit": "%", "size": 100 },
            "background_background": "classic",
            "background_color": "#FAFAFAF0",
            "z_index": 1
          }
        },
        {
          "id": "prem-about-content",
          "elType": "container",
          "settings": {
            "flex_direction": "column",
            "flex_align_items": "center",
            "flex_gap": { "unit": "px", "size": 16 },
            "z_index": 2
          },
          "elements": [
            {
              "id": "prem-about-title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "About [COMPANY NAME]",
                "html_tag": "h1",
                "align": "center",
                "typography_font_family": "Playfair Display",
                "typography_font_size": { "unit": "px", "size": 52 },
                "typography_font_size_tablet": { "unit": "px", "size": 40 },
                "typography_font_size_mobile": { "unit": "px", "size": 30 },
                "typography_font_weight": "600",
                "color": "#1A3A5C"
              }
            },
            {
              "id": "prem-about-sub",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Premium [TRADE] Services in [CITY, STATE]",
                "html_tag": "h2",
                "align": "center",
                "typography_font_family": "Lato",
                "typography_font_size": { "unit": "px", "size": 22 },
                "typography_font_weight": "300",
                "color": "#2D2D2D"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "prem-about-story",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#FFFFFF",
