{
  "version": "0.4",
  "title": "Green Quote",
  "type": "page",
  "content": [
    {
      "id": "green-quote-hero",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#F7FAF7",
        "min_height": {
          "unit": "vh",
          "size": 40
        },
        "padding": {
          "unit": "px",
          "top": 140,
          "right": 40,
          "bottom": 80,
          "left": 40,
          "isLinked": false
        },
        "flex_direction": "column",
        "flex_align_items": "center",
        "flex_justify_content": "center",
        "flex_gap": {
          "unit": "px",
          "size": 16
        }
      },
      "elements": [
        {
          "id": "green-q-h1",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "Get a Free Quote",
            "html_tag": "h1",
            "align": "center",
            "typography_font_family": "Inter",
            "typography_font_size": {
              "unit": "px",
              "size": 52
            },
            "typography_font_weight": "700",
            "color": "#1B5E20"
          }
        },
        {
          "id": "green-q-sub",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "No obligation. Fast response.",
            "html_tag": "h2",
            "align": "center",
            "typography_font_family": "Inter",
            "typography_font_size": {
              "unit": "px",
              "size": 22
            },
            "typography_font_weight": "400",
            "color": "#2E7D32"
          }
        }
      ]
    },
    {
      "id": "green-quote-body",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "padding": {
          "unit": "px",
          "top": 90,
          "right": 40,
          "bottom": 90,
          "left": 40,
          "isLinked": false
        },
        "flex_direction": "row",
        "flex_wrap": "wrap",
        "flex_gap": {
          "unit": "px",
          "size": 60
        },
        "flex_justify_content": "center"
      },
      "elements": [
        {
          "id": "green-quote-info",
          "elType": "container",
          "settings": {
            "width": {
              "unit": "%",
              "size": 35
            },
            "width_tablet": {
              "unit": "%",
              "size": 100
            },
            "width_mobile": {
              "unit": "%",
              "size": 100
            },
            "flex_direction": "column",
            "flex_gap": {
              "unit": "px",
              "size": 28
            }
          },
          "elements": [
            {
              "id": "green-qi-name",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "[COMPANY NAME]",
                "html_tag": "h2",
                "typography_font_family": "Inter",
                "typography_font_size": {
                  "unit": "px",
                  "size": 32
                },
                "typography_font_weight": "700",
                "color": "#2E7D32"
              }
            },
            {
              "id": "green-qi-tag",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "[TAGLINE]",
                "typography_font_family": "Inter",
                "typography_font_size": {
                  "unit": "px",
                  "size": 17
                },
                "text_color": "#2E7D32"
              }
            },
            {
              "id": "green-qi-phone",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color:#444444;font-family:Inter,sans-serif;font-size:17px;'>📞 <a href='tel:[PHONE]' style='color:#2E7D32;text-decoration:none;font-weight:600;'>[PHONE]</a></p>"
              }
            },
            {
              "id": "green-qi-area",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color:#777777;font-family:Inter,sans-serif;font-size:15px;'>Proudly serving [CITY, STATE] and surrounding areas.</p>"
              }
            }
          ]
        },
        {
          "id": "green-quote-form",
          "elType": "container",
          "settings": {
            "width": {
              "unit": "%",
              "size": 50
            },
            "width_tablet": {
              "unit": "%",
              "size": 100
            },
            "width_mobile": {
              "unit": "%",
              "size": 100
            },
            "background_background": "classic",
            "background_color": "#F7FAF7",
            "border_radius": {
              "unit": "px",
              "top": 8,
              "right": 8,
              "bottom": 8,
              "left": 8,
              "isLinked": true
            },
            "padding": {
              "unit": "px",
              "top": 48,
              "right": 40,
              "bottom": 48,
              "left": 40,
              "isLinked": false
            },
            "flex_direction": "column",
            "flex_gap": {
              "unit": "px",
              "size": 24
            }
          },
          "elements": [
            {
              "id": "green-qf-title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Request Your Free Estimate",
                "html_tag": "h2",
                "typography_font_family": "Inter",
                "typography_font_size": {
                  "unit": "px",
                  "size": 28
                },
                "typography_font_weight": "700",
                "color": "#1B5E20"
              }
            },
            {
              "id": "green-qf-text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "Call us at <strong style='color:#2E7D32;'>[PHONE]</strong> or email <strong style='color:#2E7D32;'>[EMAIL]</strong>. We'll get back to you within 24 hours.",
                "typography_font_family": "Inter",
                "typography_font_size": {
                  "unit": "px",
                  "size": 16
                },
                "text_color": "#555555"
              }
            },
            {
              "id": "green-qf-btn",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Call [PHONE] Now",
                "link": {
                  "url": "tel:[PHONE]"
                },
                "size": "lg",
                "button_background_color": "#2E7D32",
                "button_text_color": "#FFFFFF",
                "border_radius": {
                  "unit": "px",
                  "top": 6,
                  "right": 6,
                  "bottom": 6,
                  "left": 6,
                  "isLinked": true
                },
                "button_padding": {
                  "unit": "px",
                  "top": 18,
                  "right": 40,
                  "bottom": 18,
                  "left": 40,
                  "isLinked": false
                }
              }
            }
          ]
        }
      ]
    }
  ]
}