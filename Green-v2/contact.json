{
  "version": "0.4",
  "title": "Green Contact",
  "type": "page",
  "content": [
    {
      "id": "green-contact-hero",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#F7FAF7",
        "min_height": {
          "unit": "vh",
          "size": 40
        },
        "padding": {
          "unit": "px",
          "top": 140,
          "right": 40,
          "bottom": 80,
          "left": 40,
          "isLinked": false
        },
        "flex_direction": "column",
        "flex_align_items": "center",
        "flex_justify_content": "center",
        "flex_gap": {
          "unit": "px",
          "size": 16
        }
      },
      "elements": [
        {
          "id": "green-ct-h1",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "Contact Us",
            "html_tag": "h1",
            "align": "center",
            "typography_font_family": "Inter",
            "typography_font_size": {
              "unit": "px",
              "size": 52
            },
            "typography_font_weight": "700",
            "color": "#1B5E20"
          }
        },
        {
          "id": "green-ct-sub",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "We're Here to Help",
            "html_tag": "h2",
            "align": "center",
            "typography_font_family": "Inter",
            "typography_font_size": {
              "unit": "px",
              "size": 22
            },
            "typography_font_weight": "400",
            "color": "#2E7D32"
          }
        }
      ]
    },
    {
      "id": "green-contact-body",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "padding": {
          "unit": "px",
          "top": 90,
          "right": 40,
          "bottom": 90,
          "left": 40,
          "isLinked": false
        },
        "flex_direction": "row",
        "flex_wrap": "wrap",
        "flex_gap": {
          "unit": "px",
          "size": 60
        },
        "flex_justify_content": "center"
      },
      "elements": [
        {
          "id": "green-contact-info",
          "elType": "container",
          "settings": {
            "width": {
              "unit": "%",
              "size": 35
            },
            "width_tablet": {
              "unit": "%",
              "size": 100
            },
            "width_mobile": {
              "unit": "%",
              "size": 100
            },
            "flex_direction": "column",
            "flex_gap": {
              "unit": "px",
              "size": 32
            }
          },
          "elements": [
            {
              "id": "green-ci-title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Get In Touch",
                "html_tag": "h2",
                "typography_font_family": "Inter",
                "typography_font_size": {
                  "unit": "px",
                  "size": 34
                },
                "typography_font_weight": "700",
                "color": "#2E7D32"
              }
            },
            {
              "id": "green-ci-phone",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color:#2E7D32;font-family:Inter,sans-serif;font-size:13px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:4px;'>Phone</p><p style='color:#212121;font-family:Inter,sans-serif;font-size:20px;font-weight:500;'><a href='tel:[PHONE]' style='color:#212121;text-decoration:none;'>[PHONE]</a></p>"
              }
            },
            {
              "id": "green-ci-email",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color:#2E7D32;font-family:Inter,sans-serif;font-size:13px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:4px;'>Email</p><p style='color:#212121;font-family:Inter,sans-serif;font-size:18px;'><a href='mailto:[EMAIL]' style='color:#212121;text-decoration:none;'>[EMAIL]</a></p>"
              }
            },
            {
              "id": "green-ci-address",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color:#2E7D32;font-family:Inter,sans-serif;font-size:13px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:4px;'>Address</p><p style='color:#212121;font-family:Inter,sans-serif;font-size:17px;'>[ADDRESS]</p>"
              }
            },
            {
              "id": "green-ci-area",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color:#2E7D32;font-family:Inter,sans-serif;font-size:13px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:4px;'>Service Area</p><p style='color:#212121;font-family:Inter,sans-serif;font-size:17px;'>[CITY, STATE] and surrounding areas</p>"
              }
            }
          ]
        },
        {
          "id": "green-contact-cta",
          "elType": "container",
          "settings": {
            "width": {
              "unit": "%",
              "size": 45
            },
            "width_tablet": {
              "unit": "%",
              "size": 100
            },
            "width_mobile": {
              "unit": "%",
              "size": 100
            },
            "background_background": "classic",
            "background_color": "#F7FAF7",
            "border_radius": {
              "unit": "px",
              "top": 8,
              "right": 8,
              "bottom": 8,
              "left": 8,
              "isLinked": true
            },
            "padding": {
              "unit": "px",
              "top": 48,
              "right": 40,
              "bottom": 48,
              "left": 40,
              "isLinked": false
            },
            "flex_direction": "column",
            "flex_gap": {
              "unit": "px",
              "size": 24
            }
          },
          "elements": [
            {
              "id": "green-cta-title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Request a Free Estimate",
                "html_tag": "h2",
                "typography_font_family": "Inter",
                "typography_font_size": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_weight": "700",
                "color": "#1B5E20"
              }
            },
            {
              "id": "green-cta-text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "Call us at <strong style='color:#2E7D32;'>[PHONE]</strong> or visit our quote page for a detailed estimate. We serve [CITY, STATE] and surrounding areas.",
                "typography_font_family": "Inter",
                "typography_font_size": {
                  "unit": "px",
                  "size": 16
                },
                "text_color": "#555555"
              }
            },
            {
              "id": "green-cta-btn",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Get a Free Quote",
                "link": {
                  "url": "/quote"
                },
                "size": "lg",
                "button_background_color": "#2E7D32",
                "button_text_color": "#FFFFFF",
                "border_radius": {
                  "unit": "px",
                  "top": 6,
                  "right": 6,
                  "bottom": 6,
                  "left": 6,
                  "isLinked": true
                },
                "button_padding": {
                  "unit": "px",
                  "top": 16,
                  "right": 40,
                  "bottom": 16,
                  "left": 40,
                  "isLinked": false
                }
              }
            }
          ]
        }
      ]
    }
  ]
}