{
  "version": "0.4",
  "title": "Green Header",
  "type": "header",
  "content": [
    {
      "id": "green-header-wrap",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "box_shadow_box_shadow_type": "yes",
        "box_shadow_box_shadow": { "horizontal": 0, "vertical": 2, "blur": 12, "spread": 0, "color": "#0000001A" },
        "padding": { "unit": "px", "top": 18, "right": 40, "bottom": 18, "left": 40, "isLinked": false },
        "padding_tablet": { "unit": "px", "top": 14, "right": 24, "bottom": 14, "left": 24, "isLinked": false },
        "padding_mobile": { "unit": "px", "top": 12, "right": 16, "bottom": 12, "left": 16, "isLinked": false },
        "flex_direction": "row",
        "flex_align_items": "center",
        "flex_justify_content": "space-between"
      },
      "elements": [
        { "id": "green-logo", "elType": "widget", "widgetType": "image", "settings": { "_wp_img": "logo", "image": { "url": "" }, "image_size": "medium", "width": { "unit": "px", "size": 150 }, "width_tablet": { "unit": "px", "size": 120 }, "width_mobile": { "unit": "px", "size": 100 } } },
        { "id": "green-nav", "elType": "widget", "widgetType": "navigation-menu", "settings": { "layout": "horizontal", "typography_font_family": "Inter", "typography_font_size": { "unit": "px", "size": 14 }, "typography_font_weight": "500", "color_menu_item": "#444444", "color_menu_item_hover": "#2E7D32", "color_menu_item_active": "#2E7D32" } },
        { "id": "green-header-cta", "elType": "widget", "widgetType": "button", "settings": { "text": "Get a Quote", "link": { "url": "/quote" }, "typography_font_family": "Inter", "typography_font_size": { "unit": "px", "size": 14 }, "typography_font_weight": "600", "button_background_color": "#2E7D32", "button_text_color": "#FFFFFF", "border_radius": { "unit": "px", "top": 6, "right": 6, "bottom": 6, "left": 6, "isLinked": true }, "button_padding": { "unit": "px", "top": 11, "right": 22, "bottom": 11, "left": 22, "isLinked": false } } }
      ]
    }
  ]
}