          {
            "id": "green-footer-instabid",
            "elType": "widget",
            "widgetType": "text-editor",
            "settings": {
              "editor": "<p style='color:#999999;font-family:Inter,sans-serif;font-size:12px;text-align:center;margin:0;'>Powered by InstaBid</p>",
