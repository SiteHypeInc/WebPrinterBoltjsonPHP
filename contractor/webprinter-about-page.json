                  "settings": {
                    "editor": "<p style='font-family: DM Mono; font-size: 13px; color: #C8A96E; letter-spacing: 1px;'>[FOUNDED YEAR] | [CITY, STATE] | [LICENSE #XXXXX]</p>"
