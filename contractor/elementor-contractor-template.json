              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='text-align: center; font-size: 20px; color: #C8A96E; margin-top: 20px; margin-bottom: 40px; font-family: DM Sans;'>[TAGLINE - e.g., Premium Roofing & Exterior Solutions]</p>"
