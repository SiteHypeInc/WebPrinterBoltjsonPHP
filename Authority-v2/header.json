{
  "version": "0.4",
  "title": "Authority Header",
  "type": "header",
  "content": [
    {
      "id": "auth-header-wrap",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#0D0D0D",
        "padding": {
          "unit": "px",
          "top": 20,
          "right": 40,
          "bottom": 20,
          "left": 40,
          "isLinked": false
        },
        "padding_tablet": {
          "unit": "px",
          "top": 16,
          "right": 24,
          "bottom": 16,
          "left": 24,
          "isLinked": false
        },
        "padding_mobile": {
          "unit": "px",
          "top": 14,
          "right": 16,
          "bottom": 14,
          "left": 16,
          "isLinked": false
        },
        "flex_direction": "row",
        "flex_align_items": "center",
        "flex_justify_content": "space-between"
      },
      "elements": [
        {
          "id": "auth-logo",
          "elType": "widget",
          "widgetType": "image",
          "settings": {
            "_wp_img": "logo",
            "image": {
              "url": ""
            },
            "image_size": "medium",
            "width": {
              "unit": "px",
              "size": 160
            },
            "width_tablet": {
              "unit": "px",
              "size": 130
            },
            "width_mobile": {
              "unit": "px",
              "size": 110
            }
          }
        },
        {
          "id": "auth-nav",
          "elType": "widget",
          "widgetType": "navigation-menu",
          "settings": {
            "layout": "horizontal",
            "typography_font_family": "Inter",
            "typography_font_size": {
              "unit": "px",
              "size": 13
            },
            "typography_font_weight": "500",
            "typography_letter_spacing": {
              "unit": "px",
              "size": 1
            },
            "typography_text_transform": "uppercase",
            "color_menu_item": "#F8F5F0CC",
            "color_menu_item_hover": "#C9A84C",
            "color_menu_item_active": "#C9A84C",
            "pointer": "none",
            "animation_duration": 250
          }
        },
        {
          "id": "auth-header-cta",
          "elType": "widget",
          "widgetType": "button",
          "settings": {
            "text": "Get a Quote",
            "link": {
              "url": "/quote"
            },
            "typography_font_family": "Inter",
            "typography_font_size": {
              "unit": "px",
              "size": 13
            },
            "typography_font_weight": "500",
            "typography_letter_spacing": {
              "unit": "px",
              "size": 0.5
            },
            "button_background_color": "#C9A84C",
            "button_text_color": "#0D0D0D",
            "border_radius": {
              "unit": "px",
              "top": 2,
              "right": 2,
              "bottom": 2,
              "left": 2,
              "isLinked": true
            },
            "button_padding": {
              "unit": "px",
              "top": 12,
              "right": 24,
              "bottom": 12,
              "left": 24,
              "isLinked": false
            }
          }
        }
      ]
    }
  ]
}