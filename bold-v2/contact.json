{
  "content": [
    {
      "id": "contact-hero",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#1A1A1A",
        "padding": { "unit": "px", "top": "120", "right": "24", "bottom": "60", "left": "24" },
        "padding_tablet": { "unit": "px", "top": "100", "right": "20", "bottom": "50", "left": "20" },
        "padding_mobile": { "unit": "px", "top": "80", "right": "16", "bottom": "40", "left": "16" }
      },
      "elements": [
        {
          "id": "contact-hero-inner",
          "elType": "container",
          "settings": {
            "content_width": "boxed",
            "flex_direction": "column",
            "flex_align_items": "center",
            "flex_gap": { "unit": "px", "row": 20 },
            "flex_gap_tablet": { "unit": "px", "row": 16 },
            "flex_gap_mobile": { "unit": "px", "row": 14 }
          },
          "elements": [
            {
              "id": "contact-hero-heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "CONTACT US",
                "header_size": "h1",
                "typography_typography": "custom",
                "typography_font_family": "Oswald",
                "typography_font_size": { "unit": "px", "size": 64 },
                "typography_font_size_tablet": { "unit": "px", "size": 52 },
                "typography_font_size_mobile": { "unit": "px", "size": 38 },
                "typography_font_weight": "700",
                "typography_text_transform": "uppercase",
                "typography_letter_spacing": { "unit": "px", "size": 2 },
                "title_color": "#FFFFFF",
                "align": "center"
              }
            },
            {
              "id": "contact-hero-text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color: #E65100; font-family: Roboto; font-size: 18px; text-align: center; margin: 0;'>Let's talk about your [TRADE] project in [CITY, STATE]</p>",
                "typography_typography": "custom",
                "typography_font_size": { "unit": "px", "size": 18 }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "contact-info-section",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#F5F5F5",
        "padding": { "unit": "px", "top": "80", "right": "24", "bottom": "80", "left": "24" },
        "padding_tablet": { "unit": "px", "top": "60", "right": "20", "bottom": "60", "left": "20" },
        "padding_mobile": { "unit": "px", "top": "50", "right": "16", "bottom": "50", "left": "16" }
      },
      "elements": [
        {
          "id": "contact-info-inner",
          "elType": "container",
          "settings": {
            "content_width": "boxed",
            "flex_direction": "row",
            "flex_direction_tablet": "row",
            "flex_direction_mobile": "column",
            "flex_gap": { "unit": "px", "column": 60, "row": 40 },
            "flex_gap_tablet": { "unit": "px", "column": 40, "row": 32 },
            "flex_gap_mobile": { "unit": "px", "row": 32 }
          },
          "elements": [
            {
              "id": "contact-info-box",
              "elType": "container",
              "settings": {
                "width": { "unit": "%", "size": 50 },
                "width_tablet": { "unit": "%", "size": 50 },
                "width_mobile": { "unit": "%", "size": 100 },
                "background_background": "classic",
                "background_color": "#FFFFFF",
                "border_border": "solid",
                "border_width": { "unit": "px", "top": 0, "right": 0, "bottom": 4, "left": 0 },
                "border_color": "#E65100",
                "padding": { "unit": "px", "top": "40", "right": "40", "bottom": "40", "left": "40" },
                "padding_tablet": { "unit": "px", "top": "32", "right": "32", "bottom": "32", "left": "32" },
                "padding_mobile": { "unit": "px", "top": "24", "right": "24", "bottom": "24", "left": "24" },
                "flex_direction": "column",
                "flex_gap": { "unit": "px", "row": 32 }
              },
              "elements": [
                { "id": "contact-info-heading", "elType": "widget", "widgetType": "heading", "settings": { "title": "GET IN TOUCH", "header_size": "h2", "typography_font_family": "Oswald", "typography_font_size": { "unit": "px", "size": 36 }, "typography_font_weight": "700", "typography_text_transform": "uppercase", "title_color": "#1A1A1A" } },
                {
                  "id": "contact-phone-item",
                  "elType": "container",
                  "settings": { "flex_direction": "column", "flex_gap": { "unit": "px", "row": 8 } },
                  "elements": [
                    { "id": "contact-phone-label", "elType": "widget", "widgetType": "heading", "settings": { "title": "PHONE", "header_size": "h4", "typography_font_family": "Oswald", "typography_font_size": { "unit": "px", "size": 16 }, "typography_font_weight": "600", "typography_text_transform": "uppercase", "title_color": "#E65100" } },
                    { "id": "contact-phone-value", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='font-family: Roboto; font-size: 20px; margin: 0;'><a href='tel:[PHONE]' style='color: #1A1A1A; text-decoration: none; font-weight: 500;'>[PHONE]</a></p>" } }
                  ]
                },
                {
                  "id": "contact-email-item",
                  "elType": "container",
                  "settings": { "flex_direction": "column", "flex_gap": { "unit": "px", "row": 8 } },
                  "elements": [
                    { "id": "contact-email-label", "elType": "widget", "widgetType": "heading", "settings": { "title": "EMAIL", "header_size": "h4", "typography_font_family": "Oswald", "typography_font_size": { "unit": "px", "size": 16 }, "typography_font_weight": "600", "typography_text_transform": "uppercase", "title_color": "#E65100" } },
                    { "id": "contact-email-value", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='font-family: Roboto; font-size: 18px; margin: 0;'><a href='mailto:[EMAIL]' style='color: #1A1A1A; text-decoration: none;'>[EMAIL]</a></p>" } }
                  ]
                },
                {
                  "id": "contact-location-item",
                  "elType": "container",
                  "settings": { "flex_direction": "column", "flex_gap": { "unit": "px", "row": 8 } },
                  "elements": [
                    { "id": "contact-location-label", "elType": "widget", "widgetType": "heading", "settings": { "title": "LOCATION", "header_size": "h4", "typography_font_family": "Oswald", "typography_font_size": { "unit": "px", "size": 16 }, "typography_font_weight": "600", "typography_text_transform": "uppercase", "title_color": "#E65100" } },
                    { "id": "contact-location-value", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='font-family: Roboto; font-size: 18px; color: #1A1A1A; margin: 0;'>[CITY, STATE]</p>" } }
                  ]
                },
                {
                  "id": "contact-hours-item",
                  "elType": "container",
                  "settings": { "flex_direction": "column", "flex_gap": { "unit": "px", "row": 8 } },
                  "elements": [
                    { "id": "contact-hours-label", "elType": "widget", "widgetType": "heading", "settings": { "title": "HOURS", "header_size": "h4", "typography_font_family": "Oswald", "typography_font_size": { "unit": "px", "size": 16 }, "typography_font_weight": "600", "typography_text_transform": "uppercase", "title_color": "#E65100" } },
                    { "id": "contact-hours-value", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='font-family: Roboto; font-size: 16px; line-height: 1.8; color: #4A4A4A; margin: 0;'>Monday – Friday: 7:00 AM – 6:00 PM<br>Saturday: 8:00 AM – 4:00 PM<br>Sunday: Closed</p>" } }
                  ]
                }
              ]
            },
            {
              "id": "contact-form-box",
              "elType": "container",
              "settings": {
                "width": { "unit": "%", "size": 50 },
                "width_tablet": { "unit": "%", "size": 50 },
                "width_mobile": { "unit": "%", "size": 100 },
                "background_background": "classic",
                "background_color": "#FFFFFF",
                "border_border": "solid",
                "border_width": { "unit": "px", "top": 0, "right": 0, "bottom": 4, "left": 0 },
                "border_color": "#E65100",
                "padding": { "unit": "px", "top": "40", "right": "40", "bottom": "40", "left": "40" },
                "padding_tablet": { "unit": "px", "top": "32", "right": "32", "bottom": "32", "left": "32" },
                "padding_mobile": { "unit": "px", "top": "24", "right": "24", "bottom": "24", "left": "24" },
                "flex_direction": "column",
                "flex_gap": { "unit": "px", "row": 24 }
              },
              "elements": [
                { "id": "contact-form-heading", "elType": "widget", "widgetType": "heading", "settings": { "title": "SEND A MESSAGE", "header_size": "h2", "typography_font_family": "Oswald", "typography_font_size": { "unit": "px", "size": 36 }, "typography_font_weight": "700", "typography_text_transform": "uppercase", "title_color": "#1A1A1A" } },
                { "id": "contact-form-text", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='font-family: Roboto; font-size: 16px; color: #4A4A4A; margin: 0;'>Fill out the form below and we'll get back to you within 24 hours. Or call us at <a href='tel:[PHONE]' style='color: #E65100; font-weight: 600;'>[PHONE]</a>.</p>" } },
                { "id": "contact-form-placeholder", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p style='font-family: Roboto; font-size: 15px; color: #999999; font-style: italic; margin: 0;'>Contact form plugin (CF7, WPForms, or Gravity Forms) will be placed here.</p>" } }
              ]
            }
          ]
        }
      ]
    }
  ],
  "page_settings": [],
  "version": "0.4",
  "title": "Bold Contact v2",
  "type": "page"
}
