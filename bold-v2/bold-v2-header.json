{
  "content": [
    {
      "id": "header-main",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#FFFFFF",
        "border_border": "solid",
        "border_width": { "unit": "px", "top": 0, "right": 0, "bottom": 3, "left": 0 },
        "border_color": "#E65100",
        "padding": { "unit": "px", "top": "24", "right": "24", "bottom": "24", "left": "24" },
        "padding_tablet": { "unit": "px", "top": "20", "right": "20", "bottom": "20", "left": "20" },
        "padding_mobile": { "unit": "px", "top": "16", "right": "16", "bottom": "16", "left": "16" },
        "position": "fixed",
        "z_index": 1000,
        "width": { "unit": "%", "size": 100 }
      },
      "elements": [
        {
          "id": "header-inner",
          "elType": "container",
          "settings": {
            "content_width": "boxed",
            "flex_direction": "row",
            "flex_direction_tablet": "row",
            "flex_direction_mobile": "row",
            "flex_justify_content": "space-between",
            "flex_align_items": "center",
            "flex_gap": { "unit": "px", "column": 40 },
            "flex_gap_tablet": { "unit": "px", "column": 24 },
            "flex_gap_mobile": { "unit": "px", "column": 16 }
          },
          "elements": [
            {
              "id": "header-logo",
              "elType": "widget",
              "widgetType": "image",
              "settings": {
                "_wp_img": "logo",
                "image": { "url": "", "id": 0 },
                "image_size": "full",
                "width": { "unit": "px", "size": 200 },
                "width_tablet": { "unit": "px", "size": 160 },
                "width_mobile": { "unit": "px", "size": 140 },
                "align": "left",
                "link_to": "custom",
                "link": { "url": "/" }
              }
            },
            {
              "id": "header-nav-wrapper",
              "elType": "container",
              "settings": {
                "flex_direction": "row",
                "flex_direction_tablet": "row",
                "flex_direction_mobile": "column",
                "flex_align_items": "center",
                "flex_gap": { "unit": "px", "column": 36 },
                "flex_gap_tablet": { "unit": "px", "column": 24 },
                "flex_gap_mobile": { "unit": "px", "row": 12 },
                "flex_grow": 1,
                "flex_justify_content": "flex-end",
                "width_mobile": { "unit": "%", "size": 100 }
              },
              "elements": [
                {
                  "id": "header-nav",
                  "elType": "widget",
                  "widgetType": "text-editor",
                  "settings": {
                    "editor": "<nav style='font-family: Oswald; font-size: 16px; font-weight: 500; text-transform: uppercase; letter-spacing: 1px;'><a href='/' style='color: #1A1A1A; text-decoration: none; margin-right: 32px;'>Home</a><a href='/services' style='color: #1A1A1A; text-decoration: none; margin-right: 32px;'>Services</a><a href='/about' style='color: #1A1A1A; text-decoration: none; margin-right: 32px;'>About</a><a href='/contact' style='color: #1A1A1A; text-decoration: none;'>Contact</a></nav>",
                    "typography_typography": "custom",
                    "typography_font_size": { "unit": "px", "size": 16 },
                    "typography_font_size_tablet": { "unit": "px", "size": 15 },
                    "typography_font_size_mobile": { "unit": "px", "size": 14 }
                  }
                },
                {
                  "id": "header-cta",
                  "elType": "widget",
                  "widgetType": "button",
                  "settings": {
                    "text": "GET QUOTE",
                    "link": { "url": "/quote" },
                    "size": "md",
                    "typography_typography": "custom",
                    "typography_font_family": "Oswald",
                    "typography_font_size": { "unit": "px", "size": 16 },
                    "typography_font_size_tablet": { "unit": "px", "size": 15 },
                    "typography_font_size_mobile": { "unit": "px", "size": 14 },
                    "typography_font_weight": "600",
                    "typography_text_transform": "uppercase",
                    "typography_letter_spacing": { "unit": "px", "size": 1 },
                    "button_background_color": "#E65100",
                    "button_text_color": "#FFFFFF",
                    "border_radius": { "unit": "px", "top": 0, "right": 0, "bottom": 0, "left": 0 },
                    "button_padding": { "unit": "px", "top": 16, "right": 32, "bottom": 16, "left": 32 },
                    "button_padding_tablet": { "unit": "px", "top": 14, "right": 28, "bottom": 14, "left": 28 },
                    "button_padding_mobile": { "unit": "px", "top": 12, "right": 24, "bottom": 12, "left": 24 }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "page_settings": [],
  "version": "0.4",
  "title": "Bold Header v2",
  "type": "section"
}
