              "row": 40
            }
          },
          "elements": [
            {
              "id": "philosophy-heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Design Philosophy",
                "html_tag": "h2",
                "align": "center",
                "color": "#2C1810",
                "typography_typography": "custom",
                "typography_font_size": {
                  "unit": "px",
                  "size": 44
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 36
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 30
                },
                "typography_font_weight": "300",
                "typography_line_height": {
                  "unit": "em",
                  "size": 1.3
                }
              }
            },
            {
              "id": "philosophy-text-1",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color: #2C1810; font-size: 17px; line-height: 1.9; margin: 0; font-weight: 300; text-align: left;'>I believe the most successful interiors aren't dictated by fleeting trends, but rather emerge from a deep understanding of how people live, what they value, and what brings them joy. My approach is collaborative and deeply personal—each project is a unique dialogue between client and designer.</p>"
              }
            },
            {
              "id": "philosophy-text-2",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color: #2C1810; font-size: 17px; line-height: 1.9; margin: 0; font-weight: 300; text-align: left;'>I draw inspiration from classical architecture, fine art, natural materials, and global craft traditions. The result is layered, nuanced spaces that feel both timeless and entirely contemporary—interiors that honor history while embracing modern living.</p>"
              }
            },
            {
              "id": "philosophy-text-3",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color: #2C1810; font-size: 17px; line-height: 1.9; margin: 0; font-weight: 300; text-align: left;'>Above all, I'm committed to creating spaces that endure—environments that grow richer and more meaningful with time, reflecting the lives and stories of those who inhabit them.</p>"
              }
            }
          ]
        }
      ]
    },
