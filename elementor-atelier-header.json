{
  "content": [
    {
      "id": "header-main",
      "elType": "container",
      "settings": {
        "content_width": "full",
        "background_background": "classic",
        "background_color": "#F5EFE6",
        "padding": {
          "unit": "px",
          "top": 20,
          "right": 60,
          "bottom": 20,
          "left": 60,
          "isLinked": false
        },
        "padding_tablet": {
          "unit": "px",
          "top": 15,
          "right": 30,
          "bottom": 15,
          "left": 30,
          "isLinked": false
        },
        "padding_mobile": {
          "unit": "px",
          "top": 12,
          "right": 20,
          "bottom": 12,
          "left": 20,
          "isLinked": false
        },
        "border_border": "solid",
        "border_width": {
          "unit": "px",
          "top": 0,
          "right": 0,
          "bottom": 1,
          "left": 0,
          "isLinked": false
        },
        "border_color": "#C9A96E33",
        "flex_direction": "row",
        "flex_align_items": "center",
        "flex_justify_content": "space-between",
        "position": "fixed",
        "z_index": 1000,
        "width": {
          "unit": "%",
          "size": 100
        },
        "width_tablet": {
          "unit": "%",
          "size": 100
        },
        "width_mobile": {
          "unit": "%",
          "size": 100
        }
      },
      "elements": [
        {
          "id": "logo-container",
          "elType": "container",
          "settings": {
            "flex_direction": "row",
            "flex_align_items": "center",
            "width": {
              "unit": "auto"
            },
            "width_tablet": {
              "unit": "auto"
            },
            "width_mobile": {
              "unit": "auto"
            }
          },
          "elements": [
            {
              "id": "logo-image",
              "elType": "widget",
              "widgetType": "image",
              "settings": {
                "image": {
                  "url": ""
                },
                "image_size": "full",
                "width": {
                  "unit": "px",
                  "size": 180
                },
                "width_tablet": {
                  "unit": "px",
                  "size": 150
                },
                "width_mobile": {
                  "unit": "px",
                  "size": 130
                },
                "align": "left"
              }
            }
          ]
        },
        {
          "id": "nav-container",
          "elType": "container",
          "settings": {
            "flex_direction": "row",
            "flex_align_items": "center",
            "flex_gap": {
              "unit": "px",
              "column": 40,
              "row": 0
            },
            "width": {
              "unit": "auto"
            },
            "width_tablet": {
              "unit": "auto"
            },
            "width_mobile": {
              "unit": "%",
              "size": 100
            },
            "flex_direction_mobile": "column",
            "flex_gap_mobile": {
              "unit": "px",
              "column": 0,
              "row": 15
            }
          },
          "elements": [
            {
              "id": "nav-links",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<style>\n  .atelier-nav a {\n    color: #2C1810;\n    text-decoration: none;\n    font-size: 15px;\n    font-weight: 400;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    transition: color 0.3s ease;\n  }\n  .atelier-nav a:hover {\n    color: #C9A96E;\n  }\n  @media (max-width: 1024px) {\n    .atelier-nav a {\n      font-size: 14px;\n    }\n  }\n  @media (max-width: 767px) {\n    .atelier-nav {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 12px;\n    }\n    .atelier-nav a {\n      font-size: 13px;\n    }\n  }\n</style>\n<div class=\"atelier-nav\">\n  <a href=\"/\">Home</a>\n  <a href=\"/portfolio\">Portfolio</a>\n  <a href=\"/services\">Services</a>\n  <a href=\"/about\">About</a>\n  <a href=\"/contact\">Contact</a>\n</div>"
              }
            },
            {
              "id": "cta-button",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Begin Your Project",
                "link": {
                  "url": "/quote"
                },
                "align": "right",
                "align_tablet": "center",
                "align_mobile": "center",
                "button_type": "default",
                "typography_typography": "custom",
                "typography_font_size": {
                  "unit": "px",
                  "size": 14
                },
                "typography_font_size_tablet": {
                  "unit": "px",
                  "size": 13
                },
                "typography_font_size_mobile": {
                  "unit": "px",
                  "size": 12
                },
                "typography_font_weight": "400",
                "typography_letter_spacing": {
                  "unit": "px",
                  "size": 1.5
                },
                "typography_text_transform": "uppercase",
                "background_color": "#2C1810",
                "color": "#F5EFE6",
                "border_radius": {
                  "unit": "px",
                  "top": 0,
                  "right": 0,
                  "bottom": 0,
                  "left": 0,
                  "isLinked": true
                },
                "padding": {
                  "unit": "px",
                  "top": 14,
                  "right": 32,
                  "bottom": 14,
                  "left": 32,
                  "isLinked": false
                },
                "padding_tablet": {
                  "unit": "px",
                  "top": 12,
                  "right": 28,
                  "bottom": 12,
                  "left": 28,
                  "isLinked": false
                },
                "padding_mobile": {
                  "unit": "px",
                  "top": 10,
                  "right": 24,
                  "bottom": 10,
                  "left": 24,
                  "isLinked": false
                },
                "button_background_hover_color": "#C9A96E",
                "hover_animation": "none"
              }
            }
          ]
        }
      ]
    }
  ]
}
